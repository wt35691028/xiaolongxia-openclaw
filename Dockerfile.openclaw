FROM 1186258278/openclaw-zh:2026.3.2-nightly.202603040725

# 设置环境变量
ENV ZAI_API_KEY=${ZAI_API_KEY}

# 暴露端口
EXPOSE 18789

# 配置并启动 OpenClaw Gateway（后台运行保持容器活跃）
CMD ["sh", "-c", "openclaw config set gateway.mode local && openclaw config set agents.defaults.model zai/glm-4.7 && openclaw config set gateway.auth.token abc && openclaw config set gateway.controlUi.dangerouslyAllowHostHeaderOriginFallback true && openclaw gateway --bind lan && tail -f /dev/null"]
